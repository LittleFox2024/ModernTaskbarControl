<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ModernTaskbarControl.Page1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernTaskbarControl"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">


    <Page.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!--Style TargetType="CheckBox"-->
            <!--Setter Property="VerticalAlignment" Value="Top"/-->
        <!--/Style-->
    </Page.Resources>

    <StackPanel Spacing="8">
        
        <!--Taskbar expander-->
        <Expander Header="Taskbar Appearance" FontWeight="Bold" Width="405" HorizontalAlignment="Center" IsExpanded="True">
            <Expander.Content>
                <StackPanel Width="365" Margin="0">
                    <Grid RowSpacing="0" ColumnSpacing="5" Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!--Auto-hide taskbar-->
                        <CheckBox 
                            x:Name="autoHideTbCheck" 
                            Checked="autoHideTbCheck_Checked" 
                            Unchecked="autoHideTbCheck_Unchecked"
                            Grid.Row="0"
                            Grid.Column="0">
                        </CheckBox>
                        <TextBlock 
                            Text="Auto-hide taskbar" 
                            Grid.Column="1"
                            Grid.Row="0">
                        </TextBlock>

                        <!--Use small icons-->
                        <CheckBox 
                            x:Name="useSmallIconsCheck"
                            Checked="useSmallIconsCheck_Checked"
                            Unchecked="useSmallIconsCheck_Unchecked"
                            Grid.Row="1"
                            Grid.Column="0">

                        </CheckBox>
                        <TextBlock
                            Text="Use small icons"
                            Grid.Column="1"
                            Grid.Row="1">
                        </TextBlock>
                    </Grid>
                    <Grid RowSpacing="0" ColumnSpacing="0" Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="6*"/>
                        </Grid.ColumnDefinitions>

                        <!--Centered taskbar-->
                        <TextBlock
                            Text="Icon location on taskbar:"
                            Grid.Row="0"
                            Grid.Column="0">
                        </TextBlock>
                        <ComboBox 
                            x:Name="centerTbCombobox" 
                            SelectionChanged="centerTbCombobox_SelectionChanged"
                            PlaceholderText="Center"
                            Width="160"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Grid.Row="0"
                            Grid.Column="1"
                            FontWeight="Normal">
                            <x:String>Left</x:String>
                            <x:String>Center</x:String>
                        </ComboBox>

                        <!--Taskbar buttons-->
                        <TextBlock
                            Text="Taskbar buttons:"
                            Grid.Row="1"
                            Grid.Column="0"
                            TextWrapping="WrapWholeWords">
                        </TextBlock>
                        <ComboBox
                            x:Name="tbButtonsCombobox"
                            SelectionChanged="tbButtonsCombobox_SelectionChanged"
                            PlaceholderText="Always combine"
                            Width="160"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Grid.Row="1"
                            Grid.Column="1"
                            FontWeight="Normal">
                            <x:String>Always combine</x:String>
                            <x:String>Combine when full</x:String>
                            <x:String>Never combine</x:String>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Expander.Content>
        </Expander>

        <!--Notification area expander-->
        <Expander Header="Notification Area" FontWeight="Bold" Width="405" HorizontalAlignment="Center" IsExpanded="True">
            <Grid RowSpacing="0" ColumnSpacing="5" Margin="0" Width="365">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="Customize which notifications will appear in the notification area"
                    HorizontalAlignment="Left"
                    TextWrapping="WrapWholeWords"
                    Grid.Row="0"
                    Grid.Column="0">
                </TextBlock>
                <Button
                    Content="Customize..."
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Click="selectIconsBtn_Click"
                    Grid.Row="0"
                    Grid.Column="1">
                </Button>
            </Grid>
        </Expander>
        
        <!--Taskbar items expander-->
        <Expander Header="Taskbar items" FontWeight="Bold" Width="405" HorizontalAlignment="Center" IsExpanded="True">
            <StackPanel Width="365" Margin="0">

                <Grid RowSpacing="0" ColumnSpacing="5" Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!--Task view-->
                    <CheckBox
                        x:Name="taskViewCheck"
                        Checked="taskViewCheck_Checked"
                        Unchecked="taskViewCheck_Unchecked"
                        VerticalAlignment="Top"
                        Grid.Row="0"
                        Grid.Column="0">
                    </CheckBox>
                    <TextBlock
                        Text="Show task view button"
                        Grid.Row="0"
                        Grid.Column="1">
                    </TextBlock>
                </Grid>

                <Grid RowSpacing="0" ColumnSpacing="0" Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="6*"/>
                    </Grid.ColumnDefinitions>

                    <!--Search-->
                    <TextBlock
                        Text="Search"
                        Grid.Row="0"
                        Grid.Column="0">
                    </TextBlock>
                    <ComboBox
                        x:Name="searchComboBox"
                        SelectionChanged="searchComboBox_SelectionChanged"
                        PlaceholderText="Hide"
                        Width="180"
                        HorizontalAlignment="Right"
                        Grid.Row="0"
                        Grid.Column="1"
                        FontWeight="Normal">
                        <x:String>Hide</x:String>
                        <x:String>Search icon only</x:String>
                        <x:String>Search icon and label</x:String>
                        <x:String>Search box</x:String>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Expander>




    </StackPanel>
</Page>
