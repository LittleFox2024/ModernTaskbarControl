<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ModernTaskbarControl.Page1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernTaskbarControl"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>

        <Rectangle Fill="White" Stroke="LightGray" StrokeThickness="1" RadiusX="5" RadiusY="5"
                   Margin="-3,-7,-3,300"></Rectangle>
        
        <TextBlock Text="Taskbar Appearance" FontWeight="Bold" Margin="5,1,0,0"></TextBlock>
        
        <!--Auto-hide taskbar-->
        <CheckBox x:Name="autoHideTbCheck" Checked="autoHideTbCheck_Checked" Unchecked="autoHideTbCheck_Unchecked"
                  VerticalAlignment="Top" Margin="5,24,10,10"></CheckBox>
        <TextBlock Text="Auto-hide taskbar" Margin="30,30,10,10"></TextBlock>
        
        <!--Use small icons-->
        <CheckBox x:Name="useSmallIconsCheck" Checked="useSmallIconsCheck_Checked" Unchecked="useSmallIconsCheck_Unchecked"
                  VerticalAlignment="Top" Margin="5,50,10,10"></CheckBox>
        <TextBlock Text="Use small icons" Margin="30,57,10,10"></TextBlock>
        
        <!--Centered taskbar-->
        <TextBlock Text="Icon location on taskbar:" Margin="5,95,10,10"></TextBlock>
        <ComboBox x:Name="centerTbCombobox" SelectionChanged="centerTbCombobox_SelectionChanged" 
                  Margin="150,90,15,5" PlaceholderText="Center" Width="180" HorizontalAlignment="Right">
            <x:String>Left</x:String>
            <x:String>Center</x:String>
        </ComboBox>
        
        <!--Taskbar buttons-->
        <TextBlock Text="Taskbar buttons:" Margin="5,135,10,10"></TextBlock>
        <ComboBox x:Name="tbButtonsCombobox" SelectionChanged="tbButtonsCombobox_SelectionChanged" 
                  Margin="150,130,15,5" PlaceholderText="Always combine" Width="180" HorizontalAlignment="Right">
            <x:String>Always combine</x:String>
            <x:String>Combine when full</x:String>
            <x:String>Never combine</x:String>
        </ComboBox>
       

        <!--Second set-->
        <Rectangle Fill="White" Stroke="LightGray" StrokeThickness="1" RadiusX="5" RadiusY="5"
           Margin="-3,200,-3,200"></Rectangle>

        <TextBlock Text="Notification area" FontWeight="Bold" Margin="5,208,0,0"></TextBlock>
        <TextBlock Text="Customize which notifications will appear in the notification area" 
                   Margin="5,235,115,5" HorizontalAlignment="Left" TextWrapping="WrapWholeWords"></TextBlock>
        <Button Content="Customize..." Margin="5,243,15,5" VerticalAlignment="Top" HorizontalAlignment="Right" Click="selectIconsBtn_Click"></Button>


        <!--And finally...-->
        <Rectangle Fill="White" Stroke="LightGray" StrokeThickness="1" RadiusX="5" RadiusY="5"
           Margin="-3,300,-3,5"></Rectangle>
        <TextBlock Text="Taskbar items" FontWeight="Bold" Margin="5,308,0,0"></TextBlock>
        
        <!--Search-->
        <TextBlock Text="Search" Margin="5,335,10,10"></TextBlock>
        <ComboBox x:Name="searchComboBox" SelectionChanged="searchComboBox_SelectionChanged"
                  Margin="150,332,15,5" PlaceholderText="Hide" Width="180" HorizontalAlignment="Right">
            <x:String>Hide</x:String>
            <x:String>Search icon only</x:String>
            <x:String>Search icon and label</x:String>
            <x:String>Search box</x:String>
        </ComboBox>
        
        <!--Task view-->
        <CheckBox x:Name="taskViewCheck" Checked="taskViewCheck_Checked" Unchecked="taskViewCheck_Unchecked"
                  VerticalAlignment="Top" Margin="5,365,10,10"></CheckBox>
        <TextBlock Text="Show task view button" Margin="30,370,10,10"></TextBlock>


    </Grid>
</Page>
